{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@kharon-platform/ui/*": ["packages/ui/src/*"],
      "@kharon-platform/types": ["packages/types/src/index"],
      "@kharon-platform/types/*": ["packages/types/src/*"],
      "@kharon-platform/config": ["packages/config/src/index"],
      "@kharon-platform/config/*": ["packages/config/src/*"],
      "@kharon-platform/validators": ["packages/validators/src/index"],
      "@kharon-platform/validators/*": ["packages/validators/src/*"],
      "@kharon-platform/auth": ["packages/auth/src/index"],
      "@kharon-platform/auth/*": ["packages/auth/src/*"],
      "@kharon-platform/integrations/*": ["packages/integrations/src/*"],
      "@kharon-platform/documents/*": ["packages/documents/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "out"]
}