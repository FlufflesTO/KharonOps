# Runtime mode
KHARON_MODE=local

# Session
SESSION_KEYS=replace_with_32_plus_char_key_one,replace_with_32_plus_char_key_two
SESSION_COOKIE_NAME=kharon_session
SESSION_TTL_SECONDS=28800

# Public URLS
WORKER_PUBLIC_URL=https://kharon-api.example.workers.dev
SITE_PUBLIC_URL=https://www.kharonops.example

# Google OIDC
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional Cloudflare Access JWT validation (enable when Access protects Worker domain)
CF_ACCESS_ENABLED=false
CF_ACCESS_AUD=replace_with_access_application_audience
CF_ACCESS_JWKS_URL=https://your-team.cloudflareaccess.com/cdn-cgi/access/certs
# Optional strict issuer check, example:
# CF_ACCESS_ISSUER=https://your-team.cloudflareaccess.com
CF_ACCESS_ISSUER=
# Alternative to CF_ACCESS_JWKS_URL (mainly for deterministic local tests)
CF_ACCESS_JWKS_JSON=

# Google service account (production mode)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Workspace rails
WORKBOOK_SPREADSHEET_ID=spreadsheet_id
GOOGLE_DRIVE_ROOT_FOLDER_ID=drive_root_folder_id
GOOGLE_DOCCARD_TEMPLATE_ID=jobcard_template_doc_id
GOOGLE_SERVICE_REPORT_TEMPLATE_ID=service_report_template_doc_id
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=...
GOOGLE_CALENDAR_ID=primary
GMAIL_SENDER_ADDRESS=ops@kharonfs.co.za

# Netlify -> Worker proxy origin
NETLIFY_WORKER_ORIGIN=https://kharon-api.example.workers.dev
